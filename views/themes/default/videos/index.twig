{# views/themes/default/videos/index.twig #}
{% extends "layouts/main.twig" %}

{% block full_width_content %}
<div class="video-hub-page text-slate-200 min-h-screen py-16 selection:bg-red-600 selection:text-white">
  <div class="max-w-7xl mx-auto px-6">
    
    <header class="mb-14 text-center sm:text-left">
      <h1 class="text-4xl sm:text-5xl font-extrabold text-white tracking-tight">
        Browse Series
      </h1>
      <p class="text-neutral-400 mt-3 text-lg max-w-2xl font-light leading-relaxed">
        Explore complex theological concepts, deep structural breakdowns, and historical scriptural contexts through beautifully crafted animations.
      </p>
      
      <div class="flex flex-wrap gap-2 mt-8 justify-center sm:justify-start">
        <button class="filter-btn px-5 py-2 text-xs font-bold font-mono tracking-widest uppercase rounded-full border transition-all duration-300 bg-white border-white text-black" 
                data-filter="all">
          All Streams
        </button>
        
        {% for type in filters %}
          {% set filterSlug = type|lower|trim|replace({' ': '-'}) %}
          <button class="filter-btn px-5 py-2 text-xs font-bold font-mono tracking-widest uppercase rounded-full border transition-all duration-300 bg-transparent border-neutral-800 text-neutral-400 hover:text-white hover:border-neutral-500" 
                  data-filter="{{ filterSlug }}">
            {{ type }}
          </button>
        {% endfor %}
      </div>
    </header>

    <main class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-x-5 gap-y-10" id="categoriesGrid">
    {% for category in categories %}
      
      {% set categoryFilter = category.testament|lower|trim|replace({' ': '-'}) %}

      <div class="category-card group relative flex flex-col h-full bg-neutral-950 rounded-md overflow-visible transition-all duration-300 ease-out hover:scale-105 hover:z-20" 
           data-category="{{ categoryFilter }}">
           
        <div class="relative w-full aspect-video rounded-t-md overflow-hidden bg-neutral-900 shadow-md border border-neutral-900 group-hover:border-neutral-800 flex items-center justify-center shrink-0">
          
          {% if category.thumb %}
            <img src="{{ base_url }}/public/img/thumbnails/{{ category.thumb }}" 
                 alt="{{ category.name }}" 
                 class="w-full h-full object-cover transition-transform duration-500"
                 loading="lazy"
                 onerror="this.onerror=null; this.src='{{ base_url }}/img/thumbnails/fallback-category.jpg';">
          {% else %}
            <div class="w-full h-full flex flex-col items-center justify-center bg-neutral-950/60 p-4">
              <span class="text-4xl mb-2 opacity-80">{{ category.icon|default('🎬') }}</span>
              <span class="text-xs uppercase tracking-widest text-neutral-600 font-mono">[ Preview Missing ]</span>
            </div>
          {% endif %}

          <div class="absolute inset-0 bg-gradient-to-t from-neutral-950 via-transparent to-transparent opacity-60"></div>
          
          <span class="absolute top-3 left-3 px-2 py-0.5 text-[10px] font-mono tracking-widest font-black uppercase rounded bg-neutral-950/80 backdrop-blur-md border border-neutral-800 text-neutral-400">
            {{ category.testament|default('all') }}
          </span>
        </div>
        
        <div class="flex flex-col flex-grow p-4 bg-neutral-950 rounded-b-md border-x border-b border-neutral-900 transition-colors duration-300 group-hover:bg-neutral-900 group-hover:border-neutral-800 shadow-2xl">
          
          <div class="flex flex-col items-start sm:flex-row sm:items-center sm:justify-between gap-x-4 mb-3 shrink-0">
            <h3 class="text-base font-bold text-white tracking-tight truncate w-full sm:w-auto">
              {{ category.name }}
            </h3>
            <span class="text-[11px] font-mono font-extrabold text-red-500 tracking-tight shrink-0 bg-red-500/10 border border-red-500/20 px-2 py-0.5 rounded mt-1.5 sm:mt-0">
              {{ category.video_count|default(0) }} Episodes
            </span>
          </div>
          
          <div class="flex flex-col justify-center flex-grow py-2">
            <p class="text-neutral-400 text-xs leading-relaxed line-clamp-2">
              {{ category.description }}
            </p>
          </div>
          
          <div class="mt-4 pt-3 border-t border-neutral-900 group-hover:border-neutral-800 transition-colors duration-300 shrink-0">
            <a href="{{ base_url }}/videos/{{ category.slug }}" 
               class="inline-flex items-center justify-center gap-1.5 w-full bg-blue-500 text-white font-bold text-xs tracking-wide py-2 px-4 rounded hover:bg-neutral-200 transition-colors duration-200">
              <span>▶</span> Explore Collection
            </a>
          </div>
        </div>

      </div>
    {% else %}
      <div class="col-span-full text-center py-20 bg-neutral-950 rounded-xl border border-neutral-900">
          <p class="text-neutral-500 font-mono text-xs tracking-wider uppercase">No media series matched your selection criteria.</p>
      </div>
    {% endfor %}
  </main>
</div>

<script>
document.addEventListener('DOMContentLoaded', () => {
  const filterButtons = document.querySelectorAll('.filter-btn');
  const cards = document.querySelectorAll('.category-card');

  filterButtons.forEach(button => {
    button.addEventListener('click', () => {
      // Dynamic Netflix Filter Active/Inactive Class Transforms
      filterButtons.forEach(btn => {
         btn.classList.remove('bg-white', 'border-white', 'text-black');
         btn.classList.add('bg-transparent', 'border-neutral-800', 'text-neutral-400', 'hover:text-white', 'hover:border-neutral-500');
      });
      
      button.classList.add('bg-white', 'border-white', 'text-black');
      button.classList.remove('bg-transparent', 'border-neutral-800', 'text-neutral-400', 'hover:text-white', 'hover:border-neutral-500');

      const selectedFilter = button.getAttribute('data-filter');

      cards.forEach(card => {
        const cardCategory = card.getAttribute('data-category');

        if (selectedFilter === 'all' || cardCategory === selectedFilter) {
          card.classList.remove('hidden');
        } else {
          card.classList.add('hidden');
        }
      });
    });
  });
});
</script>
{% endblock %}
