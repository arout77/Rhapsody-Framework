{% extends "layouts/main.twig" %}

{% block full_width_content %}
<div class="max-w-5xl mx-auto px-4 py-6">
    
    {# Breadcrumb Navigation #}
    <nav class="flex items-center text-sm font-medium text-gray-500 dark:text-gray-400 mb-6" aria-label="Breadcrumb">
        <a href="{{ base_url }}/videos" class="hover:text-gray-700 dark:hover:text-gray-200 transition-colors">Videos</a>
        <svg class="flex-shrink-0 mx-2 h-5 w-5 text-gray-400" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"/>
        </svg>
        <a href="{{ base_url }}/videos/{{ video.category_slug }}" class="hover:text-gray-700 dark:hover:text-gray-200 transition-colors">{{ video.category_name }}</a>
        <svg class="flex-shrink-0 mx-2 h-5 w-5 text-gray-400" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"/>
        </svg>
        <span class="text-gray-800 dark:text-gray-100 font-semibold truncate" aria-current="page">Episode {{ video.episode_number }}: {{ video.title }}</span>
    </nav>

    {# Video Player Container Layer #}
    <div class="bg-black rounded-xl overflow-hidden shadow-2xl border border-gray-200 dark:border-gray-800 mb-6">
        <div class="relative w-full aspect-video">
            {% if video.video_source == 'local' %}
                {# 
                   Native HTML5 player for locally stored content.
                   Matches your comment rule: builds via category slug + video file slug + manual .mp4 extension
                #}
                <video class="absolute top-0 left-0 w-full h-full" controls poster="{{ base_url }}/public/img/thumbnails/{{ video.thumbnail }}">
                    <source src="{{ base_url }}/public/videos/{{ video.category_slug }}/{{ video.slug }}.mp4" type="video/mp4">
                    Your browser does not support the video tag.
                </video>
            {% else %}
                {# 
                   External streaming player fallback layer (YouTube/Vimeo Embed).
                   Assumes external links or iframe targets reside inside your 'video_id' or a dedicated text column.
                #}
                <iframe class="absolute top-0 left-0 w-full h-full" 
                        src="{{ video.video_id }}" 
                        title="{{ video.title }}" 
                        frameborder="0" 
                        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" 
                        allowfullscreen>
                </iframe>
            {% endif %}
        </div>
    </div>

    {# Video Details Meta Info #}
    <div class="bg-white dark:bg-gray-900 rounded-xl p-6 border border-gray-100 dark:border-gray-800 shadow-sm">
        <div class="flex flex-wrap items-center justify-between gap-4 mb-4">
            <div>
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800 dark:bg-blue-900 dark:text-blue-200 mb-2">
                    Episode {{ video.episode_number }}
                </span>
                <h1 class="text-2xl md:text-3xl font-extrabold text-gray-900 dark:text-white leading-tight">
                    {{ video.title }}
                </h1>
            </div>
            
            <a href="{{ base_url }}/videos/{{ video.category_slug }}" 
               class="inline-flex items-center text-sm font-semibold text-blue-600 dark:text-blue-400 hover:underline">
                &larr; Return to Series Playlist
            </a>
        </div>

        {% if video.description %}
            <hr class="border-gray-100 dark:border-gray-800 my-4">
            <h3 class="text-sm font-bold text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-2">About this Episode</h3>
            <p class="text-gray-700 dark:text-gray-300 text-base leading-relaxed whitespace-pre-line">
                {{ video.description }}
            </p>
        {% endif %}
    </div>

</div>
{% endblock %}