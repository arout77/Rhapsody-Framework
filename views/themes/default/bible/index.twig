{% extends "layouts/main.twig" %}

{% block content %}

    <section class="section-heading">
        <span class="eyebrow">Scripture Library</span>
        <h1>Choose a Bible Translation</h1>
        <p>Select a public-domain translation, then open any book from the navigation above.</p>
    </section>

    <div class="version-grid grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-5 gap-4 mt-8">
    
        <button data-version-target="kjv" class="version-card text-left p-4 rounded-xl bg-slate-900/40 border border-slate-800 hover:border-sky-500/50 transition-all group">
            <h4 class="font-bold text-white group-hover:text-sky-400 transition-colors">King James Version</h4>
            <p class="text-xs text-slate-400 mt-1 font-mono">Classic English phrasing with familiar verse structure.</p>
        </button>
        
        <button data-version-target="asv" class="version-card text-left p-4 rounded-xl bg-slate-900/40 border border-slate-800 hover:border-sky-500/50 transition-all group">
            <h4 class="font-bold text-white group-hover:text-sky-400 transition-colors">American Standard</h4>
            <p class="text-xs text-slate-400 mt-1 font-mono">A literal English translation published in 1901.</p>
        </button>

        <button data-version-target="web" class="version-card text-left p-4 rounded-xl bg-slate-900/40 border border-slate-800 hover:border-sky-500/50 transition-all group">
            <h4 class="font-bold text-white group-hover:text-sky-400 transition-colors">World English Bible</h4>
            <p class="text-xs text-slate-400 mt-1 font-mono">A modern public-domain translation in contemporary English.</p>
        </button>

        <button data-version-target="bbe" class="version-card text-left p-4 rounded-xl bg-slate-900/40 border border-slate-800 hover:border-sky-500/50 transition-all group">
            <h4 class="font-bold text-white group-hover:text-sky-400 transition-colors">Basic English (BBE)</h4>
            <p class="text-xs text-slate-400 mt-1 font-mono">Simplified English with a smaller core vocabulary.</p>
        </button>

        <button data-version-target="rv_1909" class="version-card text-left p-4 rounded-xl bg-slate-900/40 border border-slate-800 hover:border-sky-500/50 transition-all group">
            <h4 class="font-bold text-white group-hover:text-sky-400 transition-colors">Reina-Valera (1909)</h4>
            <p class="text-xs text-slate-400 mt-1 font-mono">A historic Spanish translation for Spanish-speaking readers.</p>
        </button>

    </div>

    <script>
    document.addEventListener('DOMContentLoaded', () => {
        // Synchronize current visual active highlights if matching the active selection state
        const currentActive = localStorage.getItem('user_bible_version') || '{{ active_version|default("kjv") }}';
        const activeCard = document.querySelector(`[data-version-target="${currentActive}"]`);
        if (activeCard) {
            activeCard.classList.remove('bg-slate-900/40', 'border-slate-800');
            activeCard.classList.add('bg-sky-950/20', 'border-sky-500/70', 'ring-1', 'ring-sky-500/30');
        }

        // Trigger update routine via the master navbar selector
        document.querySelectorAll('[data-version-target]').forEach(card => {
            card.addEventListener('click', () => {
                const targetVersion = card.getAttribute('data-version-target');
                const masterSelector = document.getElementById('bibleVersionSelect');
                if (masterSelector) {
                    masterSelector.value = targetVersion;
                    masterSelector.dispatchEvent(new Event('change'));
                } else {
                    // Fallback implementation if navbar selection field is missing on a viewport
                    localStorage.setItem('user_bible_version', targetVersion);
                    const currentUrl = new URL(window.location.href);
                    currentUrl.searchParams.set('v', targetVersion);
                    window.location.href = currentUrl.toString();
                }
            });
        });
    });
    </script>

{% endblock %}
