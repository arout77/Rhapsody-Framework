<!-- Header, Main Content, Footer -->
<header class="bg-indigo-400 dark:bg-gray-800 opacity-75 text-white shadow-md sticky top-0 z-40">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-16">
            <div class="flex-shrink-0">
                <a href="{{ base_url }}/" class="flex items-center space-x-3 group text-2xl logo">
                    {# <img src="{{ base_url }}/public/img/rhap.png"> #}
                    Rhapsody
                </a>
            </div>

            <nav class="hidden md:flex md:items-center md:space-x-8">
                <a href="https://github.com/arout77/Rhapsody-Framework" target="_blank" rel="noopener noreferrer" class="text-white" style="display: inline-flex; align-items: center; gap: 8px; text-decoration: none;">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M12 0C5.37 0 0 5.37 0 12c0 5.3 3.438 9.8 8.205 11.387.6.113.82-.26.82-.58 0-.287-.01-1.05-.015-2.06-3.338.726-4.042-1.61-4.042-1.61-.546-1.387-1.333-1.756-1.333-1.756-1.09-.745.082-.73.082-.73 1.205.085 1.838 1.237 1.838 1.237 1.07 1.834 2.807 1.304 3.492.997.108-.775.418-1.305.762-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.468-2.38 1.235-3.22-.123-.3-.535-1.52.117-3.16 0 0 1.008-.322 3.3 1.23.96-.267 1.98-.4 3-.405 1.02.005 2.04.138 3 .405 2.29-1.552 3.297-1.23 3.297-1.23.653 1.64.24 2.86.118 3.16.768.84 1.233 1.91 1.233 3.22 0 4.61-2.804 5.62-5.476 5.92.43.37.824 1.102.824 2.22 0 1.602-.015 2.894-.015 3.287 0 .322.216.698.83.578C20.565 21.795 24 17.295 24 12c0-6.63-5.37-12-12-12z"/>
                    </svg>
                    GitHub
                </a>
                <a href="{{ base_url }}/docs" class="text-white" style="display: inline-flex; align-items: center; gap: 8px; text-decoration: none;">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M4 4C4 2.89543 4.89543 2 6 2H14L20 8V20C20 21.1046 19.1046 22 18 22H6C4.89543 22 4 21.1046 4 20V4Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
                    <path d="M14 2V8H20" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
                    <path d="M8 12H16M8 16H12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                  </svg> 
                    Documentation
                </a>
            </nav>

            <div class="flex items-center space-x-4">
                <div id="theme-switcher" class="bg-gray-200 dark:bg-gray-700 rounded-lg p-1">
                    <button id="theme-btn" class="p-2 rounded-md hover:bg-gray-300 dark:hover:bg-gray-600">
                        </button>
                </div>

                <div class="md:hidden flex items-center">
                    <button id="mobile-menu-button" class="inline-flex items-center justify-center p-2 rounded-md text-gray-700 dark:text-gray-300 hover:text-gray-900 dark:hover:text-white hover:bg-gray-100 dark:hover:bg-gray-700 focus:outline-none">
                        <svg class="h-6 w-6" stroke="currentColor" fill="none" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7" />
                        </svg>
                    </button>
                </div>
            </div>
        </div>
    </div>

    <div id="mobile-menu" class="hidden md:hidden">
        <div class="px-2 pt-2 pb-3 space-y-1 sm:px-3">
            <a href="{{ base_url }}/" class="mobile-nav-link">Home</a>
            <a href="{{ base_url }}/contact" class="mobile-nav-link">Contact</a>
            
            <hr class="dropdown-divider my-2">
            <h3 class="mobile-dropdown-header">Docs</h3>
            <a href="{{ base_url }}/docs/installation" class="mobile-nav-link pl-4">Installation & Setup</a>
            <a href="{{ base_url }}/docs/updating" class="mobile-nav-link pl-4">Updating the Framework</a>
            <a href="{{ base_url }}/docs/routing" class="mobile-nav-link pl-4">Routing</a>
            <a href="{{ base_url }}/docs/controllers" class="mobile-nav-link pl-4">Controllers & DI</a>
            <a href="{{ base_url }}/docs/views" class="mobile-nav-link pl-4">Views & Templating</a>
            <a href="{{ base_url }}/docs/validation" class="mobile-nav-link pl-4">Validation</a>
            <a href="{{ base_url }}/docs/models" class="mobile-nav-link pl-4">Basic DB (PDO)</a>
            <a href="{{ base_url }}/docs/doctrine" class="mobile-nav-link pl-4">Doctrine ORM</a>
            <a href="{{ base_url }}/docs/caching" class="mobile-nav-link pl-4">Performance & Caching</a>
            <a href="{{ base_url }}/docs/middleware" class="mobile-nav-link pl-4">Middleware & Auth</a>
            <a href="{{ base_url }}/docs/security" class="mobile-nav-link pl-4">Security (CSRF)</a>
            <a href="{{ base_url }}/docs/events" class="dropdown-link">Events & Listeners</a>
            <a href="{{ base_url }}/docs/file-uploader" class="mobile-nav-link pl-4">File Uploader</a>
            <a href="{{ base_url }}/docs/pagination" class="mobile-nav-link pl-4">Pagination</a>
            <a href="{{ base_url }}/docs/mailer" class="mobile-nav-link pl-4">Sending Mail</a>
            <a href="{{ base_url }}/docs/cli" class="mobile-nav-link pl-4">The Rhapsody Console</a>
            
            <hr class="dropdown-divider my-2">
            {% if auth.check %}
                <a href="{{ base_url }}/dashboard" class="mobile-nav-link">Dashboard</a>
                <a href="{{ base_url }}/logout" class="mobile-nav-link">Logout</a>
            {% else %}
                <a href="{{ base_url }}/login" class="mobile-nav-link">Login</a>
                <a href="{{ base_url }}/register" class="mobile-nav-link">Register</a>
            {% endif %}
        </div>
    </div>
</header>