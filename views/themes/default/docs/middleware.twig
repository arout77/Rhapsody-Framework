{% extends "docs/_layout.twig" %}

{% block doc_content %}
    <h1>Middleware & Authentication</h1>
    <p>
        Middleware filters HTTP requests before they reach your controller. Rhapsody includes <code>auth</code> and <code>guest</code> middleware out of the box, and you can create your own.
    </p>

    <h2>How Middleware Works</h2>
    <p>
        Middleware classes must implement a <code>handle(Request $request): ?Response</code> method. If the middleware returns a <code>Response</code> object (e.g., a redirect or error response), the request is short‑circuited and that response is sent immediately. If it returns <code>null</code>, the request proceeds to the next middleware or controller.
    </p>

    <h2>Configuration (No Core Edits)</h2>
    <p>
        Middleware configuration is stored in <code>config/middleware.php</code> – <strong>never modify files inside <code>/core</code></strong>. This keeps your customisations safe during framework updates.
    </p>

    <h3>The <code>middleware.php</code> File</h3>
    <pre><code class="language-php">// config/middleware.php
return [
    // Route‑specific middleware (key => class)
    'map' => [
        'auth'    => \App\Middleware\AuthMiddleware::class,
        'guest'   => \App\Middleware\GuestMiddleware::class,
        'updates' => \App\Middleware\CheckUpdatesMiddleware::class,
        // Add your own:
        // 'admin' => \App\Middleware\AdminMiddleware::class,
    ],
    // Global middleware (runs on every matched request)
    'global' => [
        \App\Middleware\VerifyCsrfTokenMiddleware::class,
    ],
];</code></pre>

    <h3>Assigning Middleware to Routes</h3>
    <p>
        Chain the <code>middleware()</code> method to your route definition using the keys defined in <code>middleware.php</code>.
    </p>
    <pre><code class="language-php">// Only for authenticated users
Router::get('/dashboard', [PageController::class, 'dashboard'])->middleware('auth');

// Only for guests
Router::get('/login', [AuthController::class, 'showLoginForm'])->middleware('guest');</code></pre>

    <h2>Creating Custom Middleware</h2>
    <ol>
        <li>Create a class in <code>app/Middleware</code> extending <code>App\Middleware\Middleware</code>.</li>
        <li>Implement the <code>handle(Request $request): ?Response</code> method.</li>
        <li>Add an entry to the <code>'map'</code> array in <code>config/middleware.php</code>.</li>
    </ol>
    <pre><code class="language-php">// Example AdminMiddleware
namespace App\Middleware;

use Core\Request;
use Core\Response;
use Core\Session;

class AdminMiddleware extends Middleware
{
    public function handle(Request $request): ?Response
    {
        if (Session::get('user_role') !== 'admin') {
            return redirect('/');
        }
        return null;
    }
}</code></pre>
    <p>Then register it in <code>config/middleware.php</code>:</p>
    <pre><code class="language-php">'map' => [
    // ...
    'admin' => \App\Middleware\AdminMiddleware::class,
],</code></pre>

    <h2>Included Middleware</h2>
    <ul>
        <li><strong><code>auth</code></strong> – redirects to <code>/login</code> if no user is logged in.</li>
        <li><strong><code>guest</code></strong> – redirects to <code>/dashboard</code> if a user is already logged in.</li>
        <li><strong><code>VerifyCsrfTokenMiddleware</code></strong> – global middleware that validates CSRF tokens on unsafe methods.</li>
    </ul>
{% endblock %}