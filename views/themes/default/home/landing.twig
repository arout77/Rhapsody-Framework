{% extends "layouts/main.twig" %}

{% block full_width_content %}
<div class="fixed inset-0 z-2 opacity-50 dark:opacity-20 pointer-events-none">
    <div class="animated-blob" style="width: 40vw;height: 40vw;top: -10vh;left: -10vw;--color-start: #720697;--color-end: #720697;--duration: 25s;--delay: 0s;--x-start: 0vw;--y-start: 0vh;--scale-start: 1;--x-mid: 20vw;--y-mid: 20vh;--scale-mid: 1.2;--x-end: 10vw;--y-end: 10vh;--scale-end: 1;"></div>
    <div class="animated-blob" style="width: 20vw;height: 30vw;top: 60vh;left: 70vw;--color-start: #1647f9;--color-end: #be03ff;--duration: 30s;--delay: 5s;--x-start: 0vw;--y-start: 0vh;--scale-start: 0.8;--x-mid: -10vw;--y-mid: -20vh;--scale-mid: 1;--x-end: 0vw;--y-end: 0vh;--scale-end: 0.8;"></div>
    <div class="animated-blob" style="width: 50vw;height: 50vw;top: 30vh;left: -30vw;--color-start: #3aa4ff;--color-end: #6a0497;--duration: 40s;--delay: 10s;--x-start: 0vw;--y-start: 0vh;--scale-start: 1.1;--x-mid: 30vw;--y-mid: -10vh;--scale-mid: 0.9;--x-end: 10vw;--y-end: 20vh;--scale-end: 1.1;"></div>
</div>

<style>
    .bg-grid { background-image: linear-gradient(to right, rgba(255, 255, 255, 0.05) 1px, transparent 1px), linear-gradient(to bottom, rgba(255, 255, 255, 0.05) 1px, transparent 1px); background-size: 3rem 3rem; }
    .feature-card { transition: transform 0.2s ease-out, box-shadow 0.2s ease-out; }
    .feature-card:hover { transform: translateY(-5px); box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04); }
    
    .marquee-container { overflow: hidden; position: relative; width: 100%; }
    .marquee { display: inline-block; white-space: nowrap; animation: marquee 60s linear infinite; }
    .marquee > span { display: inline-block; padding: 0 2rem; font-weight: 600; font-size: 1.125rem; }
    @keyframes marquee { 0% { transform: translateX(0%); } 100% { transform: translateX(-50%); } }

    /* Animated Gradient Text Style */
    .animated-gradient-text {
        background: linear-gradient(to right, #FFD700, #4B0082, #E6E6FA, #FFD700);
        background-size: 200% auto;
        -webkit-background-clip: text;
        background-clip: text;
        -webkit-text-fill-color: transparent;
        color: transparent !important;
        animation: textGradient 6s linear infinite;
    }

@keyframes textGradient {
    0% {
        background-position: 0% center;
    }
    100% {
        background-position: 200% center;
    }
}
    @keyframes textGradient {
        to { background-position: 300% center; }
    }
</style>

<section class="relative bg-black text-white min-h-[90vh] flex items-center overflow-hidden">
    <div class="absolute inset-0 z-0">
        <img src="{{ base_url }}/public/img/onthecross.png" alt="A depiction of Christ on the cross" class="w-full h-full object-cover object-center opacity-40">
        <div class="absolute inset-0 bg-black/60"></div>
        <div class="absolute inset-0 bg-grid [mask-image:radial-gradient(ellipse_at_center,white_10%,transparent_80%)]"></div>
    </div>
    
    <div class="relative container mx-auto px-6 py-24 text-center z-10 flex flex-col items-center justify-center">
        <div class="mb-4">
            <span class="inline-block font-semibold px-4 py-1 border-2 border-indigo-600 rounded-full text-indigo-300 bg-black/40">Discover. Engage. Learn.</span>
        </div>
        
        <h1 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-serif font-extrabold leading-tight tracking-tight mb-4 max-w-5xl animated-gradient-text">
            "And ye will know the truth,<br> and the truth<br> shall set ye free"
        </h1>
        
        <p class="text-xl md:text-2xl font-semibold text-gray-200 mb-12">
            - John 8:32
        </p>
        
        <div class="flex flex-col sm:flex-row justify-center items-center gap-4">
            <a href="/bible" class="sm:w-auto bg-indigo-600 hover:bg-indigo-500 text-white font-bold py-3 px-10 rounded-lg text-lg transition duration-300 transform hover:scale-105 shadow-lg">
                Read the Bible
            </a>
            <a href="/videos" class="sm:w-auto border-2 border-gray-200 bg-white/10 hover:bg-white/20 text-white font-bold py-3 px-10 rounded-lg text-lg transition duration-300 transform hover:scale-105">
                Watch Videos
            </a>
        </div>
    </div>
</section>

<div class="marquee-container bg-gray-950 text-gray-300 py-4 border-y border-gray-800">
    <div class="marquee">
        <span>Old & New Testaments</span><span class="text-indigo-400 mx-4">&#10013;</span>
        <span>Animated Video Series</span><span class="text-indigo-400 mx-4">&#10013;</span>
        <span>Daily Trivia Challenges</span><span class="text-indigo-400 mx-4">&#10013;</span>
        <span>Cross-Translation Study</span><span class="text-indigo-400 mx-4">&#10013;</span>
        <span>Interactive Quizzes</span><span class="text-indigo-400 mx-4">&#10013;</span>
        <span>Free Online Bible</span><span class="text-indigo-400 mx-4">&#10013;</span>
        <span>Biblical Commentary</span><span class="text-indigo-400 mx-4">&#10013;</span>
        <span>Old & New Testaments</span><span class="text-indigo-400 mx-4">&#10013;</span>
        <span>Animated Video Series</span><span class="text-indigo-400 mx-4">&#10013;</span>
        <span>Interactive Quizzes</span><span class="text-indigo-400 mx-4">&#10013;</span>
        <span>Biblical Commentary</span><span class="text-indigo-400 mx-4">&#10013;</span>
    </div>
</div>

<section id="discover" class="py-20 md:py-28 bg-gray-900/50">
        <div class="container mx-auto px-6">
            <div class="text-center max-w-3xl mx-auto mb-16">
                <h2 class="text-4xl md:text-5xl font-bold tracking-tight dark:text-white">Your Path to Deeper Understanding</h2>
                <p class="mt-4 text-xl dark:text-gray-300">The Faith Project provides a modern, engaging toolkit for exploring Scripture, whether you are a lifelong believer or just beginning your journey.</p>
            </div>
            <div class="grid xs:grid-cols-1 md:grid-cols-3 gap-8 text-center">
                
                <div class="bg-gray-950 p-8 rounded-xl border border-gray-800 feature-card">
                    <h3 class="text-2xl font-bold text-indigo-300 mb-4">Read & Learn</h3>
                    <p class="text-gray-300 mb-6">Explore the complete text of the Bible with intuitive navigation, easy translation switching, and insightful study tools.</p>
                    <span class="text-5xl">&#128214;</span>
                </div>
                
                <div class="bg-gray-950 p-8 rounded-xl border border-gray-800 feature-card">
                    <h3 class="text-2xl font-bold text-indigo-300 mb-4">Watch & Grow</h3>
                    <p class="text-gray-300 mb-6">Engage with complex biblical themes through beautifully animated video series designed to make the truth accessible and captivating.</p>
                    <span class="text-5xl">&#127916;</span>
                </div>
                
                <div class="bg-gray-950 p-8 rounded-xl border border-gray-800 feature-card">
                    <h3 class="text-2xl font-bold text-indigo-300 mb-4">Test Your Knowledge</h3>
                    <p class="text-gray-300 mb-6">Challenge yourself and connect with others through daily trivia and comprehensive quizzes on biblical history, people, and teachings.</p>
                    <span class="text-5xl">&#127918;</span>
                </div>
            </div>
      </div>
    </section>

    <section id="resources" class="py-20 md:py-28 bg-black dark:bg-gray-950">
        <div class="container mx-auto px-4">
            <div class="text-center max-w-3xl mx-auto mb-16">
                <h2 class="text-4xl md:text-5xl font-bold tracking-tight text-white">Explore Our Resources</h2>
                <p class="mt-4 text-xl text-gray-300 mb-12">Everything You Need for Insightful Bible Study.</p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10 z-10 relative">
                
                <div class="text-center p-6 bg-gray-900 rounded-lg shadow-lg border border-gray-800 feature-card">
                    <div class="flex items-center justify-center h-16 w-16 rounded-full bg-indigo-900 text-indigo-300 mx-auto mb-4">
                         <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5h12M9 3v2m1.048 9.5A18.022 18.022 0 016.412 9m6.088 9h7M11 21l5-10 5 10M12.751 5C11.783 11.37 9.188 16.524 5 20" /></svg>
                    </div>
                    <h3 class="text-2xl font-bold text-white mb-2">Cross-Translation Study</h3>
                    <p class="text-gray-300">Compare different versions of the Bible side-by-side (KJV, ASV, WEB, and others) to gain a clearer understanding of nuanced passages.</p>
                </div>

                <div class="text-center p-6 bg-gray-900 rounded-lg shadow-lg border border-gray-800 feature-card">
                    <div class="flex items-center justify-center h-16 w-16 rounded-full bg-indigo-900 text-indigo-300 mx-auto mb-4">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                    </div>
                    <h3 class="text-2xl font-bold text-white mb-2">Visual Commentaries</h3>
                    <p class="text-gray-300">Dive into our custom animated video series explaining biblical topics, context, and theology in an easy-to-understand visual format.</p>
                </div>

                <div class="text-center p-6 bg-gray-900 rounded-lg shadow-lg border border-gray-800 feature-card">
                     <div class="flex items-center justify-center h-16 w-16 rounded-full bg-indigo-900 text-indigo-300 mx-auto mb-4">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                    </div>
                    <h3 class="text-2xl font-bold text-white mb-2">Daily Trivia Challenges</h3>
                    <p class="text-gray-300">Test your recall of scripture and biblical history with daily trivia questions, covering everything from Genesis to Revelation.</p>
                </div>

                <div class="text-center p-6 bg-gray-900 rounded-lg shadow-lg border border-gray-800 feature-card">
                    <div class="flex items-center justify-center h-16 w-16 rounded-full bg-indigo-900 text-indigo-300 mx-auto mb-4">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" /></svg>
                    </div>
                    <h3 class="text-2xl font-bold text-white mb-2">Structural Commentaries</h3>
                    <p class="text-gray-300">Access comprehensive text breakdowns for all 66 books of the Bible, categorized by canonical groupings for contextual study.</p>
                </div>

                <div class="text-center p-6 bg-gray-900 rounded-lg shadow-lg border border-gray-800 feature-card">
                    <div class="flex items-center justify-center h-16 w-16 rounded-full bg-indigo-900 text-indigo-300 mx-auto mb-4">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z" /></svg>
                    </div>
                    <h3 class="text-2xl font-bold text-white mb-2">Personal Highlights</h3>
                    <p class="text-gray-300">Create a free account to highlight key verses, add study notes, and save your favorite resources directly within the interface.</p>
                </div>

                <div class="text-center p-6 bg-gray-900 rounded-lg shadow-lg border border-gray-800 feature-card">
                    <div class="flex items-center justify-center h-16 w-16 rounded-full bg-indigo-900 text-indigo-300 mx-auto mb-4">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
                    </div>
                    <h3 class="text-2xl font-bold text-white mb-2">Powerful Scripture Search</h3>
                    <p class="text-gray-300">Instantly find specific verses, keywords, or topics across the entire biblical text utilizing our highly optimized scripture engine.</p>
                </div>
                
            </div>
        </div>
    </section>

   
    <section class="bg-gray-950 py-24 relative overflow-hidden">
        <div class="absolute inset-0 z-0 opacity-10">
            <div class="animated-blob" style="width: 40vw;height: 40vw;top: -10vh;left: 70vw;--color-start: #1647f9;--color-end: #be03ff;--duration: 25s;--delay: 0s;"></div>
        </div>
        <div class="container mx-auto px-6 text-center relative z-10">
            <h2 class="text-4xl font-bold text-white mb-4">Start Your Symphony with the Word Today</h2>
            <p class="text-xl text-gray-300 mb-12 max-w-2xl mx-auto">Join a growing community of readers choosing a clear, captivating, and comprehensive way to engage with sacred scripture.</p>
            <a href="/bible">
                <button class="bg-indigo-600 hover:bg-indigo-500 text-white font-bold py-4 px-12 rounded-lg text-xl transition duration-300 transform hover:scale-105 shadow-xl">Start Reading Now</button>
            </a>
        </div>
    </section>
{% endblock %}